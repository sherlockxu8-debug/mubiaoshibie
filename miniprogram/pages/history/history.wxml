<view class="container">
  <view class="header">
    <view class="title">📋 检测历史</view>
    <view class="subtitle">查看所有视频检测记录</view>
  </view>

  <view wx:for="{{videoList}}" wx:key="id" class="card video-card" bindtap="goToDetail" data-id="{{item.id}}">
    <view class="video-item">
      <view class="video-icon">🎬</view>
      <view class="video-info">
        <text class="filename">{{item.filename}}</text>
        <view class="meta-row">
          <text class="meta">📷 {{item.camera_id}}</text>
          <text class="meta">📅 {{item.created_at}}</text>
        </view>
        <view wx:if="{{item.status === 'completed'}}" class="meta">
          ⏱️ {{item.duration ? item.duration.toFixed(0) + '秒' : '-'}}
        </view>
      </view>
      <view class="status-badge status-{{item.status}}">
        {{item.status === 'pending' ? '⏳' : item.status === 'processing' ? '🔄' : item.status === 'completed' ? '✅' : '❌'}}
      </view>
    </view>
  </view>

  <view wx:if="{{!loading && videoList.length === 0}}" class="empty-state">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无检测记录</text>
    <text class="empty-hint">上传视频开始检测</text>
  </view>

  <view wx:if="{{loading}}" class="loading-state">
    <text>🔄 加载中...</text>
  </view>

  <view wx:if="{{!hasMore && videoList.length > 0}}" class="no-more">
    已加载全部记录
  </view>
</view>
