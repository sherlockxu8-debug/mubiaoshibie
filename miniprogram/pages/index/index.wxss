.container {
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 40rpx 0;
  color: #fff;
}

.logo {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

.upload-card {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.picker-value {
  padding: 24rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid #e8e8e8;
  font-size: 28rpx;
}

.video-preview {
  padding: 40rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx dashed #ccc;
  text-align: center;
}

.video-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  color: #999;
}

.video-placeholder .icon {
  font-size: 60rpx;
}

.video-selected {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  color: #52c41a;
}

.video-selected .icon {
  font-size: 48rpx;
}

.video-info {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
  gap: 30rpx;
  font-size: 24rpx;
  color: #999;
}

.btn-upload {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.3);
}

.btn-upload[disabled] {
  background: #ccc;
  box-shadow: none;
}

.status {
  margin-top: 20rpx;
  text-align: center;
  color: #1890ff;
  font-size: 28rpx;
}

.loading-text {
  animation: rotate 1s linear infinite;
  display: inline-block;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.tips {
  background: rgba(255, 255, 255, 0.95);
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  color: #333;
}

.tips-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
}
