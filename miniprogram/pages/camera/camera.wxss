.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.header-left {
  flex: 1;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.btn-add {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 15rpx 30rpx;
  font-size: 26rpx;
}

.add-form {
  margin-bottom: 30rpx;
}

.form-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 25rpx;
  color: #333;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-item.half {
  flex: 1;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.form-input {
  width: 100%;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  border: 2rpx solid #e8e8e8;
  font-size: 28rpx;
  box-sizing: border-box;
}

.btn-submit {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  color: #fff;
  border: none;
  border-radius: 10rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: bold;
  margin-top: 10rpx;
}

.camera-count {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.camera-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.camera-item {
  margin-bottom: 0;
}

.camera-header {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 10rpx;
}

.camera-id-badge {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.status-dot.status-active {
  background-color: #52c41a;
}

.status-dot.status-inactive {
  background-color: #ff4d4f;
}

.camera-info {
  margin-bottom: 15rpx;
}

.camera-location {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.camera-meta-row {
  display: flex;
  gap: 15rpx;
  margin-bottom: 8rpx;
}

.camera-tag {
  font-size: 24rpx;
  color: #666;
  background-color: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.camera-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.camera-actions {
  display: flex;
  justify-content: flex-end;
}

.btn-delete {
  background-color: #fff1f0;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
  border-radius: 8rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  display: block;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 10rpx;
}
