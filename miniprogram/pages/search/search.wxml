<view class="container">
  <view class="header">
    <view class="title">🔍 搜索结果</view>
  </view>

  <view class="card search-box">
    <view class="search-row">
      <input
        class="search-input"
        type="text"
        placeholder="输入物品名称"
        bindinput="onKeywordChange"
        value="{{keyword}}"
      />
      <button class="btn-search" bindtap="doSearch">搜索</button>
    </view>

    <picker mode="selector" range="{{cameraList}}" range-key="location" bindchange="onCameraChange">
      <view class="picker-value">
        {{selectedCameraIndex >= 0 ? cameraList[selectedCameraIndex].location : '全部摄像头'}}
      </view>
    </picker>
  </view>

  <view class="result-count" wx:if="{{results.length > 0}}">
    共找到 {{results.length}} 条结果
  </view>

  <view class="result-list">
    <view wx:for="{{results}}" wx:key="id" class="card result-item">
      <view class="result-header">
        <view class="item-icon">📦</view>
        <view class="item-info">
          <text class="class-name">{{item.class_name}}</text>
          <view class="confidence-bar">
            <view class="confidence-fill" style="width: {{item.confidence * 100}}%"></view>
          </view>
          <text class="confidence-text">{{(item.confidence * 100).toFixed(1)}}% 置信度</text>
        </view>
      </view>
      <view class="result-meta">
        <text>⏱️ {{item.timestamp.toFixed(2)}}秒</text>
        <text>📷 帧 #{{item.frame_index}}</text>
        <text wx:if="{{item.video_id}}">📹 视频 #{{item.video_id}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{!loading && results.length === 0}}" class="empty-state">
    <text class="empty-icon">🔎</text>
    <text class="empty-text">暂无检测结果</text>
    <text class="empty-hint">尝试其他关键词筛选</text>
  </view>

  <view wx:if="{{loading}}" class="loading-state">
    <text>🔄 搜索中...</text>
  </view>

  <view wx:if="{{!hasMore && results.length > 0}}" class="no-more">
    已加载全部结果
  </view>
</view>
